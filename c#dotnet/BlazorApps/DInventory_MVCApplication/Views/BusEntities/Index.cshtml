@model DInventory_MVCApplication.Models.BusEntities.BusEntitiesVM
@{

    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Bus Entity Page";
}

<h2>List of Parents</h2>
<div class="row">
    <table class="table">
        @foreach (var mainEntity in Model.busParents)
        {
            <tr>
                <td>@mainEntity.BusParentID</td>
                <td>@mainEntity.BusParentName</td>
                <td>@mainEntity.CreatedDateTime</td>
            </tr>
            @foreach (var subEntity in mainEntity.ListOfBusChildren)
            {
                <tr>
                    <td>@subEntity.BusChildName</td>
                    <td>@subEntity.BusChildShortName</td>
                    <td>@subEntity.CreatedDateTime</td>
                </tr>
            }
        }
    </table>
</div>
@section Scripts{
<script>
    $(document).ready(function(){
    })
</script>
}